# Normalize text files by default
* text=auto

# Unity text assets
*.cs text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.meta text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.overrideController text eol=lf
*.playable text eol=lf
*.shader text eol=lf
*.compute text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.inputactions text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.md text eol=lf

